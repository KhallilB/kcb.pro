{
  "name": "kcb.pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "wrangler dev",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc -b && cd server && bun build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:server": "wrangler deploy --minify",
    "release": "release-it"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.17",
    "bun": "^1.2.7",
    "hono": "^4.7.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.4.1",
    "tailwindcss": "^4.0.17"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@eslint/js": "^9.21.0",
    "@release-it/bumper": "^7.0.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "release-it": "^18.1.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "wrangler": "^4.4.0"
  },
  "plugins": {
    "@release-it/bumper": {
      "in": "package.json",
      "out": "package.json"
    }
  }
